<!-- app/views/movies/index.html.erb -->
<% content_for :head do %>
  <%= stylesheet_link_tag :movies, "data-turbo-track": "reload" %>
<% end %>
<h1>Popular Movies</h1>

<% if @movies.any? %>
  <div id="movies-container">
    <% @movies.each do |movie| %>
      <div class="movie">
        <div class="movie-left">
          <%= image_tag("https://image.tmdb.org/t/p/w500#{movie['poster_path']}", class: "movie-poster") if movie['poster_path'] %>
          <div class="movie-rating">
            <% rating = (movie['vote_average'] / 2.0).round(1) %>
            <% 5.times do |i| %>
              <% if rating >= i + 1 %>
                <i class="fa-solid fa-star"></i>
              <% elsif rating >= i + 0.5 %>
                <i class="fa-solid fa-star-half-stroke"></i>
              <% else %>
                <i class="fa-regular fa-star"></i>
              <% end %>
            <% end %>
            <span class="rating-score"><%= rating %> (<%= movie['vote_count'] %> Ratings)</span>
          </div>
        </div>
        <div class="movie-details">
          <strong><%= movie['title'] %></strong><br>
          <%= movie['overview'] %><br>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p>No movies available.</p>
<% end %>
